PORT=4000
# --- Local (Docker): docker compose up -d in this folder ---
# MONGODB_URI=mongodb://127.0.0.1:27017/reseller

# --- Atlas: paste from Atlas → Connect → Drivers (replace <password>) ---
# Use Database User credentials from Atlas → Database Access (not your Atlas login email).
# If password has @ # : / ? & % + encode it: in Node REPL run encodeURIComponent('yourPassword')
# Include DB name before ?:  ...mongodb.net/reseller?retryWrites=true&w=majority&appName=...
MONGODB_URI=mongodb+srv://USER:ENCODED_PASSWORD@cluster0.xxxxx.mongodb.net/reseller?retryWrites=true&w=majority

JWT_SECRET=change-me-to-a-long-random-string

# CORS: comma-separated browser origins. If unset, defaults include localhost + https://client-reseller.vercel.app
# Override fully when you deploy under a different domain, e.g.:
# CLIENT_URL=https://your-app.vercel.app,http://localhost:5173
# CLIENT_URL=http://localhost:5173

# Cookie SameSite: defaults to cross-site mode in production (NODE_ENV=production). Set to 0/false to force Lax (same-site API+SPA only).
# Auth also returns a Bearer token for the SPA; localStorage + Authorization header works when cookies are blocked.
CROSS_SITE_COOKIES=
ADMIN_EMAILS=

# Demo billing (Rs. 150 image pack, etc.) — set false when using a real payment gateway
MOCK_PAYMENTS=true

# --- Listing images: Cloudinary (recommended for Render/production) ---
# Dashboard: https://console.cloudinary.com → Settings → API Keys (or Product environment credentials).
# Option A — single line (copy from Cloudinary dashboard "API Environment variable"):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Option B — three variables (same values as in CLOUDINARY_URL):
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=your_api_secret
#
# Optional folder prefix in your Cloudinary Media Library (default: reseller/listings):
# CLOUDINARY_FOLDER=reseller/listings
#
# If unset, images are stored on local disk under ./uploads (fine for local dev; ephemeral on Render).

# --- Clerk authentication ---
# Backend secret key from Clerk Dashboard -> API Keys
CLERK_SECRET_KEY=
# Clerk publishable key (pk_...) is also required by @clerk/express on the backend.
CLERK_PUBLISHABLE_KEY=
    